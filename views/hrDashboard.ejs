<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <title>HR Dashboard</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            background: #f4f7fb;
            padding: 36px;
            color: #0f172a;
        }

        .top-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 28px;
            flex-wrap: wrap;
            gap: 14px;
        }

        .top-bar-text h1 {
            font-size: 24px;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 4px;
        }

        .top-bar-text p {
            color: #64748b;
            font-size: 14px;
        }

        .count-pill {
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 999px;
            padding: 8px 18px;
            font-size: 13px;
            font-weight: 600;
            color: #2563eb;
            box-shadow: 0 1px 3px rgba(15, 23, 42, 0.04);
        }

        .card {
            background: white;
            border-radius: 14px;
            padding: 0;
            box-shadow: 0 2px 12px rgba(15, 23, 42, 0.06);
            overflow: hidden;
        }

        .card-header {
            padding: 20px 24px;
            border-bottom: 1px solid #eef1f6;
        }

        .card-header h2 {
            font-size: 17px;
            font-weight: 700;
            color: #1e293b;
        }

        .table-scroll {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 920px;
        }

        th {
            background: #2563eb;
            color: white;
            padding: 14px 16px;
            text-align: left;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        td {
            padding: 16px;
            border-bottom: 1px solid #eef1f6;
            font-size: 14px;
            vertical-align: top;
        }

        tbody tr {
            transition: background 0.12s ease;
        }

        tbody tr:hover {
            background: #f8fafc;
        }

        tbody tr:last-child td {
            border-bottom: none;
        }

        .cv-btn {
            display: inline-block;
            text-decoration: none;
            background: #16a34a;
            color: white;
            padding: 8px 14px;
            border-radius: 7px;
            font-size: 13px;
            font-weight: 600;
            transition: background 0.15s ease;
        }

        .cv-btn:hover {
            background: #15803d;
        }

        .status {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 700;
        }

        .status.accepted {
            background: #dcfce7;
            color: #166534;
        }

        .status.rejected {
            background: #fee2e2;
            color: #991b1b;
        }

        .status.pending {
            background: #fef9c3;
            color: #854d0e;
        }

        .ai-btn {
            background: #7c3aed;
            color: white;
            padding: 8px 14px;
            border-radius: 7px;
            font-size: 13px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            margin-top: 8px;
            transition: background 0.15s ease;
        }

        .ai-btn:hover:enabled {
            background: #6d28d9;
        }

        .ai-btn:disabled {
            background: #c4b5fd;
            cursor: not-allowed;
        }

        .score-badge {
            display: inline-block;
            padding: 4px 11px;
            border-radius: 999px;
            font-weight: 700;
            font-size: 12px;
            margin-bottom: 8px;
        }

        .score-high { background: #dcfce7; color: #166534; }
        .score-mid  { background: #fef9c3; color: #854d0e; }
        .score-low  { background: #fee2e2; color: #991b1b; }

        .ai-result {
            font-size: 13px;
            line-height: 1.55;
            color: #334155;
        }

        .ai-result p {
            margin-top: 4px;
        }

        .ai-placeholder {
            color: #94a3b8;
            font-size: 12px;
            font-style: italic;
        }

        .accept-btn {
            background: #16a34a;
            color: white;
            padding: 8px 14px;
            border-radius: 7px;
            font-size: 13px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            margin-right: 6px;
            transition: background 0.15s ease;
        }

        .accept-btn:hover:enabled {
            background: #15803d;
        }

        .reject-btn {
            background: #dc2626;
            color: white;
            padding: 8px 14px;
            border-radius: 7px;
            font-size: 13px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: background 0.15s ease;
        }

        .reject-btn:hover:enabled {
            background: #b91c1c;
        }

        .accept-btn:disabled, .reject-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .reviewed-tag {
            color: #94a3b8;
            font-size: 13px;
            font-weight: 600;
        }

        .empty-state {
            text-align: center;
            color: #94a3b8;
            font-size: 14px;
            padding: 60px 20px;
        }
    </style>
</head>
<body>

<div class="top-bar">
    <div class="top-bar-text">
        <h1>HR Recruitment Dashboard</h1>
        <p>Manage internship applicants and monitor activity</p>
    </div>
    <span class="count-pill"><%= applicants.length %> applicant<%= applicants.length === 1 ? '' : 's' %></span>
</div>

<div class="card">
    <div class="card-header">
        <h2>Applicants</h2>
    </div>

    <div class="table-scroll">
        <table>

            <thead>
                <tr>
                    <th>Student Email</th>
                    <th>Internship</th>
                    <th>Location</th>
                    <th>Status</th>
                    <th>CV</th>
                    <th>AI Analysis</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                <% if (applicants.length === 0) { %>
                <tr>
                    <td colspan="7" class="empty-state">
                        No applicants found.
                    </td>
                </tr>
                <% } else { %>
                <% applicants.forEach(a => { %>
                <tr data-id="<%= a._id %>">
                    <td><%= a.student.email %></td>
                    <td><%= a.internship.position %></td>
                    <td><%= a.internship.location.name %></td>
                    <td>
                        <span class="status <%= a.status %>">
                            <%= a.status.charAt(0).toUpperCase() + a.status.slice(1) %>
                        </span>
                    </td>
                    <td style="white-space: nowrap;">
                        <a href="<%= a.cvUrl %>" class="cv-btn">Open CV</a><br>
                        <button class="ai-btn" onclick="analyzeCV('<%= a._id %>', this)">AI Analyze</button>
                    </td>
                    <td class="ai-result-cell" style="min-width: 250px; max-width: 350px;">
                        <span class="ai-placeholder">Not analyzed yet</span>
                    </td>
                    <td style="white-space: nowrap;">
                        <% if (a.status === 'pending') { %>
                        <button class="accept-btn" onclick="updateStatus('<%= a._id %>', 'accepted', this)">Accept</button>
                        <button class="reject-btn" onclick="updateStatus('<%= a._id %>', 'rejected', this)">Reject</button>
                        <% } else { %>
                        <span class="reviewed-tag">Reviewed</span>
                        <% } %>
                    </td>
                </tr>
                <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
    const socket = io();

    function addApplicationRow(application) {
    const tbody = document.querySelector('tbody');

    const emptyRow = tbody.querySelector('td[colspan="7"]');
    if (emptyRow) {
        emptyRow.closest('tr').remove();
    }

    const row = document.createElement('tr');
    row.dataset.id = application._id;

    const statusCapitalized = application.status.charAt(0).toUpperCase() + application.status.slice(1);

    const actionsHtml = application.status === 'pending'
        ? `<button class="accept-btn" onclick="updateStatus('${application._id}', 'accepted', this)">Accept</button>
           <button class="reject-btn" onclick="updateStatus('${application._id}', 'rejected', this)">Reject</button>`
        : `<span class="reviewed-tag">Reviewed</span>`;

    row.innerHTML = `
        <td>${application.student.email}</td>
        <td>${application.internship.position}</td>
        <td>${application.internship.location.name}</td>
        <td>
            <span class="status ${application.status}">
                ${statusCapitalized}
            </span>
        </td>
        <td style="white-space: nowrap;">
            <a href="http://localhost:3000${application.cv.fileUrl}" class="cv-btn">Open CV</a><br>
            <button class="ai-btn" onclick="analyzeCV('${application._id}', this)">AI Analyze</button>
        </td>
        <td class="ai-result-cell" style="min-width: 250px; max-width: 350px;">
            <span class="ai-placeholder">Not analyzed yet</span>
        </td>
        <td style="white-space: nowrap;">
            ${actionsHtml}
        </td>
    `;

    tbody.prepend(row);
}
    function addUpdatedApplication(application)
    {
        const rows = document.querySelectorAll('tr');
        rows.forEach(row => {
            if (row.dataset.id === application._id)
            {
                row.children[4].innerHTML = `
                    <a href="http://localhost:3000${application.cv.fileUrl}" class="cv-btn">
                        Open CV (Updated)
                    </a> `;
            }
        });
    }
    socket.on('new-application', (application) => 
    {
        addApplicationRow(application);
    });
    socket.on('cv-updated', (application) => 
    {
        addUpdatedApplication(application);
    });

    async function analyzeCV(applicationId, btn) 
    {
        btn.disabled = true;
        btn.textContent = 'Analyzing...';

        try 
        {
            const res = await fetch(`/api/application/analyzeCV/${applicationId}`, { method: 'POST', credentials: 'include' });

            const data = await res.json();
            if (!res.ok) throw new Error(data);

            const scoreClass = data.score >= 70 ? 'score-high' : data.score >= 40 ? 'score-mid' : 'score-low';

            const row = btn.closest('tr');
            const resultCell = row.querySelector('.ai-result-cell');
            resultCell.innerHTML = `
                <div class="ai-result">
                    <span class="score-badge ${scoreClass}">Score: ${data.score}/100</span>
                    <p>${data.summary}</p>
                    <p><strong>Matched:</strong> ${data.matchedSkills.join(', ') || 'None'}</p>
                    <p><strong>Missing:</strong> ${data.missingSkills.join(', ') || 'None'}</p>
                </div>
            `;
            btn.textContent = 'Re-analyze';

        } 
        catch (err) 
        {
            alert('Analysis failed: ' + err.message);
            btn.textContent = 'AI Analyze';
        }

        btn.disabled = false;
    }
    async function updateStatus(applicationId, status, btn) 
    {
        btn.disabled = true;

        try 
        {
            const res = await fetch(`/api/application/update/${applicationId}`, {
                method: 'PUT',
                credentials: 'include',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status })
            });

            const data = await res.json();
            if (!res.ok) throw new Error(JSON.stringify(data));

            const row = btn.closest('tr');
            const statusCell = row.children[3];
            const actionCell = btn.closest('td');

            statusCell.innerHTML = `
                <span class="status ${status}">
                    ${status.charAt(0).toUpperCase() + status.slice(1)}
                </span>
            `;

            actionCell.innerHTML = `<span class="reviewed-tag">Reviewed</span>`;

        } 
        catch (err) 
        {
            alert('Failed: ' + err.message);
            btn.disabled = false;
        }
    }
</script>
</body>
</html>