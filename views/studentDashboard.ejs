<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Student Dashboard</title>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: Arial, sans-serif;
        background: #f4f7fb;
        padding: 36px;
        color: #0f172a;
    }

    .top-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 28px;
        flex-wrap: wrap;
        gap: 14px;
    }

    .top-bar-text h1 {
        font-size: 24px;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 4px;
    }

    .top-bar-text p {
        color: #64748b;
        font-size: 14px;
    }

    .count-pill {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 999px;
        padding: 8px 18px;
        font-size: 13px;
        font-weight: 600;
        color: #2563eb;
        box-shadow: 0 1px 3px rgba(15, 23, 42, 0.04);
    }

    .card {
        background: white;
        border-radius: 14px;
        padding: 0;
        box-shadow: 0 2px 12px rgba(15, 23, 42, 0.06);
        overflow: hidden;
    }

    .card-header {
        padding: 20px 24px;
        border-bottom: 1px solid #eef1f6;
    }

    .card-header h2 {
        font-size: 17px;
        font-weight: 700;
        color: #1e293b;
    }

    .table-scroll {
        overflow-x: auto;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        min-width: 760px;
    }

    th {
        background: #2563eb;
        color: white;
        padding: 14px 16px;
        text-align: left;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    td {
        padding: 16px;
        border-bottom: 1px solid #eef1f6;
        font-size: 14px;
    }

    tbody tr {
        transition: background 0.12s ease;
    }

    tbody tr:hover {
        background: #f8fafc;
    }

    tbody tr:last-child td {
        border-bottom: none;
    }

    .cv-btn {
        display: inline-block;
        text-decoration: none;
        background: #16a34a;
        color: white;
        padding: 8px 14px;
        border-radius: 7px;
        font-size: 13px;
        font-weight: 600;
        transition: background 0.15s ease;
    }

    .cv-btn:hover {
        background: #15803d;
    }

    .status {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
    }

    .status.accepted { background: #dcfce7; color: #166534; }
    .status.rejected { background: #fee2e2; color: #991b1b; }
    .status.pending { background: #fef9c3; color: #854d0e; }

    .empty-state {
        text-align: center;
        color: #94a3b8;
        font-size: 14px;
        padding: 60px 20px;
    }
</style>
</head>

<body>

<div class="top-bar">
    <div class="top-bar-text">
        <h1>My Applications</h1>
        <p>Track the status of every internship you've applied to</p>
    </div>
    <span class="count-pill"><%= applications.length %> application<%= applications.length === 1 ? '' : 's' %></span>
</div>

<div class="card">
    <div class="card-header">
        <h2>Applications</h2>
    </div>

    <div class="table-scroll">
        <table>
            <thead>
                <tr>
                    <th>Email</th>
                    <th>Internship</th>
                    <th>Location</th>
                    <th>Deadline</th>
                    <th>Applied At</th>
                    <th>Status</th>
                    <th>CV</th>
                </tr>
            </thead>

            <tbody>
                <% if (applications.length === 0) { %>
                    <tr>
                        <td colspan="7" class="empty-state">
                            No applications found.
                        </td>
                    </tr>
                <% } else { %>

                <% applications.forEach(a => { %>
                <tr data-id="<%= a._id %>">
                    <td><%= a.student.email %></td>
                    <td><%= a.internship.position %></td>
                    <td><%= a.internship.location.name %></td>
                    <td><%= new Date(a.internship.applicationDeadline).toLocaleDateString() %></td>
                    <td><%= new Date(a.appliedAt).toLocaleDateString() %></td>
                    <td>
                        <span class="status <%= a.status %>">
                            <%= a.status.charAt(0).toUpperCase() + a.status.slice(1) %>
                        </span>
                    </td>
                    <td>
                        <a href="<%= a.cvUrl %>" class="cv-btn">
                            Open CV
                        </a>
                    </td>
                </tr>
                <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
    const socket = io();

    function addApplicationStatus(application)
    {
        const row = document.querySelector(`tr[data-id="${application._id}"]`);
        if (!row) return;

        const statusCell = row.querySelector('.status');
        statusCell.className = `status ${application.status}`;
        statusCell.textContent = application.status.charAt(0).toUpperCase() + application.status.slice(1);

    }
    socket.on('application-update', (application) => 
    {
        addApplicationStatus(application);
    });
</script>
</body>
</html>